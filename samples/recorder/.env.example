# Base URLs (one per API, set per environment)
public_url=https://api.example.com
ops_url=https://ops.example.com
simulator_url=https://simulator.example.com

# Client credentials (client_token) - machine-to-machine auth
# Recorder fetches token if not set; omit or leave empty to skip
OAUTH_TOKEN_URL=https://auth.example.com/oauth/token
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret

# Implicit flow (ops_token) - browser-based auth
# Recorder opens browser to authorize; fetches token if not set
AUTHORIZE_URL=https://auth.example.com/authorize
BROWSER_CLIENT_ID=your_browser_client_id
REDIRECT_URI=http://localhost:7777/callback

# Optional: pre-set tokens (recorder skips fetching if set)
# client_token=...
# ops_token=...
