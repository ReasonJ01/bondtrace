{
  "name": "bondtrace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "recorder",
    "player"
  ],
  "scripts": {
    "record": "node recorder/dist/index.js",
    "play": "npm --workspace @bondtrace/player run dev",
    "build": "npm run build:recorder && npm run build:player",
    "build:recorder": "npm --workspace @bondtrace/recorder run build",
    "build:player": "npm --workspace @bondtrace/player run build",
    "deploy": "npm run build && npx wrangler pages deploy player/dist --project-name=bondtrace"
  }
}
